        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/blacklists/{{test_email}}",
          "host": ["{{base_url}}"],
          "path": ["blacklists", "{{test_email}}"]
        }
      }
    },
