    {
      "name": "GET - Consultar email en lista negra (existe)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('exist es true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.exist).to.be.true;",
              "});",
              "pm.test('Respuesta contiene blocked_reason', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('blocked_reason');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
